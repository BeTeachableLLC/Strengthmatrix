# Copy to `.env.local` and fill the values.
# Never commit `.env.local`.

# HighLevel Private Integration token (starts with `pit-...`)
GHL_PRIVATE_INTEGRATION_TOKEN=

# Your GHL Location ID
GHL_LOCATION_ID=MJHmir5Xkxz4EWxcOEj3

# Contact custom field ID (File Upload type)
GHL_FILE_UPLOAD_CUSTOM_FIELD_ID=VVlxbhO6915HUwliA3zc

# Optional: Base URL for HighLevel API (usually not needed to change)
GHL_API_BASE_URL=https://services.leadconnectorhq.com

# Existing workflow trigger URL to keep your workflow nodes running
GHL_WORKFLOW_WEBHOOK_URL=https://services.leadconnectorhq.com/hooks/MJHmir5Xkxz4EWxcOEj3/webhook-trigger/3da337e1-619a-40b5-8966-bac6ac4edee7

